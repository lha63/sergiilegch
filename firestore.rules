rules_version = '2';
// Демогийн дүрэм: нэвтэрсэн (anonymous) хэрэглэгч circle болон дэд цуглуулгуудыг
// унших/бичих эрхтэй. 2 хүний туршилтад хангалттай. ПРОДАКШНД БИШ —
// production-д тойргийн гишүүнчлэлээр (members.{uid}) хязгаарлана уу.
service cloud.firestore {
  match /databases/{database}/documents {
    match /circles/{circleId} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
